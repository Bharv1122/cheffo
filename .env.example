# Supabase (required for cloud auth + sync)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# LLM proxy — server-side only. Read by api/llm.ts; NOT VITE_-prefixed, so the
# key never reaches the client bundle (see CHE-5). In production, set these in
# the Vercel project's Environment Variables.
LLM_API_KEY=your-llm-provider-key
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Optional client flag — set to "true" only when LLM_BASE_URL targets an
# image-capable backend, to enable AI recipe images.
VITE_IMAGE_GEN_ENABLED=false

# Resend transactional email — used by api/approvals/* for vet-approval emails.
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM=Cheffo <vet-approvals@cheffodoggo.com>

# Vet-approval link origin. Set to the production URL so /vet-approve/...
# links in emails point at the right host regardless of the inbound request's
# Host header (CHE-131).
PUBLIC_APP_ORIGIN=https://chef-doggo.vercel.app

# Per-IP rate limiter (CHE-130). Salt the SHA-256 hash so the DB never stores
# raw client IPs. Set to a long random string in production.
IP_HASH_SALT=change-me-to-a-long-random-string

# Stripe — server-side only. Used by api/stripe/webhook.ts (CHE-34) and the
# future checkout endpoint (CHE-33).
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
